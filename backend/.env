# =====================================================
# NeuroScribe — Backend Environment Variables
# =====================================================

# Google OAuth Client ID
# Get it from: https://console.cloud.google.com
# APIs & Services > Credentials > Create OAuth 2.0 Client ID
# Type: Web application
# Authorized JS origins: http://localhost:5173
GOOGLE_CLIENT_ID=YOUR_GOOGLE_CLIENT_ID_HERE

# Admin email — only this Gmail gets admin role via Google OAuth
ADMIN_EMAIL=harshithreddy327@gmail.com

# Port (optional, default 5001)
PORT=5001
